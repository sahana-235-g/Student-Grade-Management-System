{
  "info": {
    "name": "Student Grade API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test User\",\"email\":\"test@test.com\",\"password\":\"password123\",\"role\":\"student\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var json = pm.response.json(); if(json.token) pm.collectionVariables.set('token', json.token);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@test.com\",\"password\":\"admin123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get Courses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/courses",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/courses",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Computer Science\",\"code\":\"CS101\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Grades",
      "item": [
        {
          "name": "Get Student Grades",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/grades/:studentId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "grades", ":studentId"],
              "variable": [{"key": "studentId", "value": "STUDENT_ID_HERE"}]
            }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Get GPA",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/stats/gpa/:studentId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats", "gpa", ":studentId"],
              "variable": [{"key": "studentId", "value": ""}]
            }
          }
        },
        {
          "name": "Get Course Average",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/stats/course-avg/:courseId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats", "course-avg", ":courseId"],
              "variable": [{"key": "courseId", "value": ""}]
            }
          }
        }
      ]
    }
  ]
}
